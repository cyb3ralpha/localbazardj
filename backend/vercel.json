{
  "version": 2,
  "builds": [
    {
      "src": "localbazar/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "localbazar/wsgi.py" },
    { "src": "/admin/(.*)", "dest": "localbazar/wsgi.py" },
    { "src": "/admin", "dest": "localbazar/wsgi.py" },
    { "src": "/static/(.*)", "dest": "localbazar/wsgi.py" },
    { "src": "/media/(.*)", "dest": "localbazar/wsgi.py" },
    { "src": "/(.*)", "dest": "localbazar/wsgi.py" }
  ]
}
